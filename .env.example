# =============================================
# WebCash Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in Project Settings > Environment Variables

# ---------------------------------------------
# SUPABASE (Required for database & auth)
# ---------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ---------------------------------------------
# BACKEND API (Required for payments)
# ---------------------------------------------
# Your deployed backend URL (e.g., https://api.yourdomain.com)
# Leave empty if using the same domain
VITE_API_URL=https://your-backend.vercel.app

# ---------------------------------------------
# OPTIONAL
# ---------------------------------------------
# Service role key (only for admin operations)
# VITE_SUPABASE_SERVICE_KEY=your_supabase_service_role_key
